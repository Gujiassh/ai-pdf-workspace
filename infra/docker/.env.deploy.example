POSTGRES_DB=ai_pdf_workspace
POSTGRES_USER=ai_pdf
POSTGRES_PASSWORD=replace-with-a-long-database-password

MINIO_ROOT_USER=replace-with-a-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-secret-key
MINIO_BUCKET=ai-pdf-workspace

AI_PDF_API_IMAGE=ai-pdf-workspace-api:local
AI_PDF_WORKER_IMAGE=ai-pdf-workspace-worker:local
AI_PDF_WEB_IMAGE=ai-pdf-workspace-web:local

AI_PDF_API_INTERNAL_TOKEN=replace-with-a-long-shared-internal-token
AI_PDF_SESSION_SECRET=replace-with-at-least-32-random-bytes
AI_PDF_OPENAI_API_KEY=replace-with-an-openai-api-key
AI_PDF_OPENAI_API_BASE=https://api.openai.com/v1

AI_PDF_EMBEDDING_PROVIDER=ollama
AI_PDF_EMBEDDING_MODEL=qwen3-embedding:0.6b
AI_PDF_EMBEDDING_VERSION=embedding-v1
AI_PDF_OLLAMA_BASE_URL=http://host.docker.internal:11434

AI_PDF_RETRIEVAL_STRATEGY=hybrid
AI_PDF_RETRIEVAL_CANDIDATE_K=10
AI_PDF_RETRIEVAL_RRF_CONSTANT=60

AI_PDF_WORKER_METRICS_HOST=0.0.0.0
AI_PDF_WORKER_METRICS_PORT=9101

AI_PDF_GENERATION_PROVIDER=openai
AI_PDF_GENERATION_MODEL=gpt-5.5

CADDY_SITE_ADDRESS=pdf.example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
MINIO_CONSOLE_PORT=9001
